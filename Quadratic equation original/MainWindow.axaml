<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:Quadratic_equation_original"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Quadratic_equation_original.MainWindow"
        
        x:DataType="local:MainWindowViewModel"

        Title="Quadratic_equation_original">


        <StackPanel Margin="180" Spacing="10">
    
        <TextBox Text="{Binding InputA, UpdateSourceTrigger=PropertyChanged}" Watermark="Введите a"/>
        <TextBox Text="{Binding InputB, UpdateSourceTrigger=PropertyChanged}" Watermark="Введите b"/>
        <TextBox Text="{Binding InputC, UpdateSourceTrigger=PropertyChanged}" Watermark="Введите c"/>
       
        <Button Name="Decide"
        Click="Decide_Click" 
        Content="Решить"></Button>

        <TextBlock Name="Result" Text="{Binding ResultText}"/>

    </StackPanel>
</Window>
