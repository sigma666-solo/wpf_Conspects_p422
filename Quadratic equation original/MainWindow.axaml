<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Quadratic_equation_original.MainWindow"
        Title="Quadratic_equation_original">


        <StackPanel Margin="180" Spacing="10">
    
        <TextBox 
        Name="AInput"
        Watermark="Введите значение а: "/>

        <TextBox 
        Name="BInput"
        Watermark="Введите значение b: "/>
        
        <TextBox 
        Name="CInput"
        Watermark="Введите значение c: "/>
        
        <Button Name="Decide"
        Click="Decide_Click" 
        Content="Решить"></Button>

        <TextBlock Name="Result" Text="Результат: "/>
    </StackPanel>
</Window>
