<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShopApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ShopApp.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Shop Database Manager"
        Width="900" Height="500"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto, *">
        
        <Border Grid.Row="0" Background="#f0f0f0" Padding="15" BorderBrush="LightGray" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="Users List from SQL" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center" 
                           Foreground="#333333"/>
                
                <Button Content="Refresh Data" 
                        Command="{Binding LoadUsers}" 
                        Padding="10,5"
                        Background="#2196F3"
                        Foreground="White"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" 
                  Margin="10"
                  ItemsSource="{Binding Users}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  GridLinesVisibility="All"
                  BorderThickness="1" 
                  BorderBrush="LightGray"
                  CanUserResizeColumns="True">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" 
                                    Binding="{Binding Id}" 
                                    Width="60" />
                
                <DataGridTextColumn Header="Username" 
                                    Binding="{Binding Username}" 
                                    Width="150" />
                
                <DataGridTextColumn Header="Full Name" 
                                    Binding="{Binding FullName}" 
                                    Width="*" />
                
                <DataGridTextColumn Header="Email" 
                                    Binding="{Binding Email}" 
                                    Width="1.5*" />
                
                <DataGridTextColumn Header="Role" 
                                    Binding="{Binding Role}" 
                                    Width="120" />
                
                <DataGridCheckBoxColumn Header="Active" 
                                        Binding="{Binding IsActive}" 
                                        Width="80" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>