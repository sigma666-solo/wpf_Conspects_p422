<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Quadratic_equation.MainWindow"
        Title="Quadratic_equation">
        
<StackPanel Margin="120" Spacing="10">
        <TextBox Name="MyInput"
                Watermark="Введите текст здесь..."/>
      
        <CheckBox Name="AllowEdit"
                Content="Разрешить редактирование"
                IsChecked="True"
                IsCheckedChanged="CheckBox_Toggled"/>

</StackPanel>       
        
</Window>
