<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Calculator_grid.MainWindow"
        Title="Avalonia Calculator"
        Width="320" Height="480">

<Grid RowDefinitions="Auto, Auto, *">
        
        <!-- Верхняя панель: Режим и История -->
        <Grid Grid.Row="0" Margin="5" ColumnDefinitions="*, *">
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="☰ " FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Обычный" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="1" Content="🕒" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" FontSize="18"/>
        </Grid>

        <!-- Дисплей калькулятора -->
        <TextBlock Grid.Row="1" Text="0" FontSize="48" Margin="10,20" TextAlignment="Right"/>

        <!-- Сетка кнопок -->
        <Grid Grid.Row="2" RowDefinitions="*, *, *, *, *, *" ColumnDefinitions="*, *, *, *">
            
            <!-- Строка 0: Память -->
            <Button Grid.Row="0" Grid.Column="0" Content="MC" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="0" Grid.Column="1" Content="MR" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="0" Grid.Column="2" Content="M+" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="0" Grid.Column="3" Content="MS" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>

            <!-- Строка 1: Функции -->
            <Button Grid.Row="1" Grid.Column="0" Content="%" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="1" Grid.Column="1" Content="CE" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="1" Grid.Column="2" Content="C" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="1" Grid.Column="3" Content="÷" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>

            <!-- Строка 2: 7-8-9 -->
            <Button Grid.Row="2" Grid.Column="0" Content="7" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="2" Grid.Column="1" Content="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="2" Grid.Column="2" Content="9" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="2" Grid.Column="3" Content="×" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>

            <!-- Строка 3: 4-5-6 -->
            <Button Grid.Row="3" Grid.Column="0" Content="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="3" Grid.Column="1" Content="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="3" Grid.Column="2" Content="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="3" Grid.Column="3" Content="-" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>

            <!-- Строка 4: 1-2-3 -->
            <Button Grid.Row="4" Grid.Column="0" Content="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="4" Grid.Column="1" Content="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="4" Grid.Column="2" Content="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="4" Grid.Column="3" Content="+" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>

            <!-- Строка 5: 0 и Итог -->
            <Button Grid.Row="5" Grid.Column="0" Content="+/-" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="5" Grid.Column="1" Content="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="5" Grid.Column="2" Content="," HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>
            <Button Grid.Row="5" Grid.Column="3" Content="=" Background="SkyBlue" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1"/>

        </Grid>
    </Grid>
</Window>